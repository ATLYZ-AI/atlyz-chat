# Atlyz Chat — environment template. Copy to .env and fill in.

# OpenAI (required)
OPENAI_API_KEY=sk-proj-...

# Lead + contact email notifications (Gmail app password)
EMAIL_FROM=hello@atlyz.com
EMAIL_PASSWORD=your-gmail-app-password

# Flask session signing — REQUIRED in production. Generate: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# Admin key — REQUIRED in production. Gates /setup/create and /chat/scrape.
ATLYZ_ADMIN_KEY=

# false in production (enables threaded debug + permissive auth fallbacks when true)
DEV_MODE=false

# Port (Railway/host sets this automatically)
PORT=5002

# Optional abuse/cost tuning
MAX_MESSAGE_CHARS=2000
MAX_KNOWLEDGE_CHARS=12000
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60
IP_RATE_LIMIT_MAX=40
